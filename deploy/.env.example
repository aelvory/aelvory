# Copy to .env in this directory and fill in the required values.
# `docker compose up` reads this automatically.

# --- Required ---

# JWT signing key. MUST be at least 32 bytes of random data.
# Generate one with:
#   openssl rand -base64 48
# or in PowerShell:
#   [Convert]::ToBase64String((1..48 | %{[byte](Get-Random -Max 256)}))
JWT_SIGNING_KEY=replace-me-with-real-secret-min-32-bytes

# Postgres password for the bundled DB container.
POSTGRES_PASSWORD=replace-me-with-strong-postgres-password

# --- Optional (defaults shown) ---

# Apply EF Core migrations on startup. Set to `true` for the first boot
# against a fresh DB. Leave `false` for rolling restarts so deploys
# don't change schema by surprise; do a one-shot:
#   RUN_MIGRATIONS=true docker compose up -d --no-deps aelvory-server
# when you intentionally want migrations applied. On failure the server
# crashes and Compose restarts it (per `restart: unless-stopped`), so
# transient issues self-heal but bad migrations are loud.
# RUN_MIGRATIONS=false

# Public domain. When set, Caddy fetches a Let's Encrypt cert for this
# host on first boot and serves HTTPS on 443. Leave empty for local
# docker-compose use; HTTP works fine on AELVORY_HTTP_PORT below.
# AELVORY_DOMAIN=eu.aelvory.com

# Host ports for Caddy. Defaults make /app/ reachable at
# http://localhost/ ; change if 80/443 are taken.
# AELVORY_HTTP_PORT=80
# AELVORY_HTTPS_PORT=443

# Image tag pins. Use a SHA tag for repeatable deploys; `latest`
# is convenient but moves under your feet.
# AELVORY_SERVER_TAG=latest
# AELVORY_WEB_TAG=latest

# Postgres user / DB name. Change only if you have an existing DB to match.
# POSTGRES_USER=aelvory
# POSTGRES_DB=aelvory

# JWT issuer/audience. Match these on any clients you build that validate.
# JWT_ISSUER=aelvory
# JWT_AUDIENCE=aelvory-clients

# ASP.NET environment. Leave at Production unless you specifically want
# the dev-only OpenAPI/Swagger UI exposed.
# ASPNETCORE_ENVIRONMENT=Production
